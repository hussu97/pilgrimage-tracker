# Pilgrimage Tracker – Web app
# Copy to .env and set values. Do not commit .env.

# Optional. When unset, the app uses relative URLs (/api/v1/...) and the Vite dev proxy
# forwards to the backend. Set for production or a different backend port.
# Use 127.0.0.1 (not localhost) on macOS to avoid IPv6 issues.
# VITE_API_URL=http://127.0.0.1:3000

# Optional. Proxy target for /api in dev (default: http://127.0.0.1:3000).
# VITE_PROXY_TARGET=http://127.0.0.1:3000
