# SoulStep – Customer Web  (apps/soulstep-customer-web)
# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env.local for local development.  Do not commit .env.local.
# In production (Cloud Run), set these as CI/CD secrets and inject them at
# build time — see PRODUCTION.md.
#
# All NEXT_PUBLIC_* variables are baked into the JavaScript bundle at build time
# and are visible to anyone who inspects the built assets.
# Never put secrets in NEXT_PUBLIC_* vars.
#
# Legend:
#   [optional]    — has a sensible built-in default; set only to override
#   [conditional] — required only when a related feature is enabled


# ── API ───────────────────────────────────────────────────────────────────────

# [optional] Dev-server proxy target for /api requests.
# Only used by the Next.js dev server — has no effect in production builds.
# Default: http://127.0.0.1:3000
# NEXT_PUBLIC_PROXY_TARGET=http://127.0.0.1:3000

# [optional] Public API base URL — used on the Developers page to render
# example curl commands and API endpoint URLs.
# Default: https://api.soul-step.org
# NEXT_PUBLIC_API_BASE_URL=https://api.soul-step.org

# [optional] Server-only internal API URL for SSR metadata fetching.
# Set this to the Cloud Run internal URL of the catalog API for low-latency
# server-side fetches that don't route through the public internet.
# Example (Cloud Run to Cloud Run): https://soulstep-catalog-api-xxxx.run.app
# Falls back to NEXT_PUBLIC_API_BASE_URL, then https://api.soul-step.org.
# Never use NEXT_PUBLIC_ prefix — this must remain server-side only.
# INTERNAL_API_URL=https://soulstep-catalog-api-xxxx.europe-west1.run.app


# ── Ads — Google AdSense ──────────────────────────────────────────────────────

# [conditional] Google AdSense publisher ID.
# Required when the backend returns ADS_ENABLED=true for this client.
# Find it in AdSense console: Ads → Overview → Publisher ID.
# When unset, the AdSense script is not loaded and no ads are shown.
# NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=ca-pub-xxxxxxxxxxxxxxxxxxxxxxxx


# ── Error Tracking — GlitchTip ────────────────────────────────────────────────

# [optional] Sentry-compatible DSN for client-side error and exception tracking.
# Get your DSN from your GlitchTip project settings at https://glitchtip.com.
# When unset, client-side error tracking is disabled.
# NEXT_PUBLIC_GLITCHTIP_DSN=https://<key>@app.glitchtip.com/<project-id>


# ── Analytics — Umami Cloud ───────────────────────────────────────────────────

# [optional] Umami Cloud website ID for privacy-friendly, cookie-free analytics.
# Sign up at https://umami.is → free plan → Add website → copy the Website ID.
# The analytics script is proxied via /umami (same-origin) to bypass ad-blockers.
# When unset, Umami analytics are disabled.
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
