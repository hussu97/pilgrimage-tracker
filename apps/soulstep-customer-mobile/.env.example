# SoulStep – Customer Mobile  (apps/soulstep-customer-mobile)
# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env for local development.  Do not commit .env.
# For EAS / CI builds, set these as EAS secrets:
#   eas secret:create --name VAR_NAME --value VALUE --scope project
#
# All EXPO_PUBLIC_* variables are bundled into the JavaScript at build time and
# are therefore visible to anyone who decompiles the app bundle.  Never put
# secrets in EXPO_PUBLIC_* vars.
#
# Legend:
#   [optional]    — has a sensible built-in default; set only to override
#   [conditional] — required only when a related feature is enabled


# ── API ───────────────────────────────────────────────────────────────────────

# [optional] Backend API base URL used by the API client.
# Default: http://127.0.0.1:3000
#
# Simulator (iOS/Android):  127.0.0.1 resolves to your machine — default works.
# Physical device / Expo Go: use your machine's LAN IP (e.g. 192.168.1.x:3000)
#   because the device cannot reach localhost on your laptop.
# Production:  set to the public Cloud Run URL.
#
# EXPO_PUBLIC_API_URL=http://127.0.0.1:3000
# Physical device (example):
# EXPO_PUBLIC_API_URL=http://192.168.1.100:3000
# Production:
# EXPO_PUBLIC_API_URL=https://api.soul-step.org


# ── Deep Links / Group Invites ────────────────────────────────────────────────

# [optional] Base URL prepended to the invite code when sharing a group invite link.
# When unset, the invite link sharing feature is disabled.
# EXPO_PUBLIC_INVITE_LINK_BASE_URL=https://soul-step.org/invite


# ── Ads — Google AdMob ───────────────────────────────────────────────────────

# [conditional] AdMob App IDs — required when the AdMob SDK is initialised in
# app.json / app.config.ts.  Get from AdMob console: Apps → App settings → App ID.
# When unset, AdMob initialisation is skipped and no ads are shown.
# EXPO_PUBLIC_ADMOB_APP_ID_IOS=ca-app-pub-xxxxxxxxxxxxxxxx~xxxxxxxxxx
# EXPO_PUBLIC_ADMOB_APP_ID_ANDROID=ca-app-pub-xxxxxxxxxxxxxxxx~xxxxxxxxxx


# ── Analytics — Umami Cloud ───────────────────────────────────────────────────

# [optional] Umami Cloud website ID for privacy-friendly, cookie-free analytics.
# Sign up at https://umami.is → free plan → Add website → copy the Website ID.
# When unset, Umami analytics are disabled.
# EXPO_PUBLIC_UMAMI_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
