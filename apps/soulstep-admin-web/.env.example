# SoulStep – Admin dashboard (apps/soulstep-admin-web)
# Copy to .env and set values. Do not commit .env.

# ── API ───────────────────────────────────────────────────────────────────────
# Optional. Backend API base URL.
# When unset, the Vite dev server proxies /api to http://127.0.0.1:3000.
# Set for production or a non-default backend port.
# Use 127.0.0.1 (not localhost) on macOS to avoid IPv6 issues.
# VITE_API_URL=http://127.0.0.1:3000
# Production:
# VITE_API_URL=https://soulstep-api-834941457147.europe-west1.run.app

# ── Frontend URL ──────────────────────────────────────────────────────────────
# Optional. Public URL of the customer-facing web frontend.
# Used in the SEO detail page to generate place preview URLs.
# When unset, defaults to https://soul-step.org.
# VITE_FRONTEND_URL=https://soul-step.org
