# SoulStep VM cron jobs — installed by vm-bootstrap.sh
# All times are UTC.

# Daily dual-database backup bundle → local /opt/soulstep/backups/ + GCS (02:00 UTC)
0 2 * * * DEPLOY_DIR=/opt/soulstep /opt/soulstep/scripts/backup-db.sh >> /var/log/soulstep-backup.log 2>&1

# Daily place sync from scraper DB to catalog DB (03:00 UTC)
0 3 * * * cd /opt/soulstep && docker compose -f docker-compose.prod.yml exec -T catalog-api python -m app.jobs.sync_places >> /var/log/soulstep-sync.log 2>&1

# Weekly orphaned-image cleanup (Monday 05:00 UTC)
0 5 * * 1 cd /opt/soulstep && docker compose -f docker-compose.prod.yml exec -T catalog-api python -m app.jobs.cleanup_orphaned_images >> /var/log/soulstep-cleanup.log 2>&1

# Weekly timezone backfill (Sunday 04:00 UTC)
0 4 * * 0 cd /opt/soulstep && docker compose -f docker-compose.prod.yml exec -T catalog-api python -m app.jobs.backfill_timezones >> /var/log/soulstep-backfill.log 2>&1
