# Root .env — used by docker-compose.yml
# Copy to .env and fill in values before running `docker compose up`

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme_strong_password

# ── Backend (soulstep-catalog-api/) ─────────────────────────────────────────
JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRE=30m
REFRESH_EXPIRE=30d

# Space-separated list of allowed CORS origins (web frontend URL(s))
CORS_ORIGINS=http://localhost

# Transactional email (Resend.com) — optional, needed for password reset
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@soulstep.app
RESET_URL_BASE=http://localhost

# ── Web frontend (apps/soulstep-customer-web/) ──────────────────────────────
# Baked in at image build time — set to your public API URL
VITE_API_URL=http://localhost:3000

# ── Data Scraper (soulstep-scraper-api/) — optional ─────────────────────────
GOOGLE_MAPS_API_KEY=
SCRAPER_TIMEZONE=UTC

# ── Port overrides (optional) ────────────────────────────────────────────────
API_PORT=3000
WEB_PORT=80
SCRAPER_PORT=8001
