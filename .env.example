# Root .env — used by docker-compose.yml only
# Copy to .env and fill in values before running `docker compose up`
# Do not commit .env.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Required. Password for the Postgres container.
POSTGRES_PASSWORD=changeme_strong_password

# ── Backend (soulstep-catalog-api/) ──────────────────────────────────────────

# Required. Long random secret for signing JWTs.
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-long-random-secret

# Optional. Access token lifetime (default: 30m). Supports '30m', '1h', '7d', or integer minutes.
JWT_EXPIRE=30m

# Optional. Refresh token lifetime (default: 30d).
REFRESH_EXPIRE=30d

# Required. Space-separated list of allowed CORS origins (your web frontend URL).
CORS_ORIGINS=http://localhost

# Optional. Public URL of the web frontend — used in sitemap, share pages, JSON-LD.
# FRONTEND_URL=https://soul-step.org

# Optional. Public URL of the API — used in RSS/Atom feed self links.
# API_BASE_URL=https://api.soul-step.org

# Optional. Transactional email (Resend.com) — needed for password-reset emails.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@soul-step.org
RESET_URL_BASE=http://localhost

# Optional. Google Places API key — required for search autocomplete.
# GOOGLE_MAPS_API_KEY=AIza...

# Optional. Ads integration.
# ADS_ENABLED=true
# ADSENSE_PUBLISHER_ID=ca-pub-7902951158656200
# ADMOB_APP_ID_IOS=ca-app-pub-xxxxxxxxxxxxxxxx~yyyyyyyyyy
# ADMOB_APP_ID_ANDROID=ca-app-pub-xxxxxxxxxxxxxxxx~yyyyyyyyyy

# Optional. Image storage backend (default: blob — stored in DB).
# IMAGE_STORAGE=gcs
# GCS_BUCKET_NAME=soulstep-images

# Optional. Mobile app version enforcement. Leave empty to disable.
# MIN_APP_VERSION_SOFT=1.0.0
# MIN_APP_VERSION_HARD=1.0.0
# LATEST_APP_VERSION=1.0.0
# APP_STORE_URL_IOS=https://apps.apple.com/app/idXXXXXXXXX
# APP_STORE_URL_ANDROID=https://play.google.com/store/apps/details?id=com.soulstep

# Optional. URL of the scraper service (for admin scraper proxy).
# DATA_SCRAPER_URL=http://localhost:8001

# ── Web frontend (apps/soulstep-customer-web/) ───────────────────────────────
# Baked into the image at build time — set to your public API URL.
VITE_API_URL=http://localhost:3000

# ── Data Scraper (soulstep-scraper-api/) — optional ──────────────────────────
GOOGLE_MAPS_API_KEY=
SCRAPER_TIMEZONE=UTC

# ── Port overrides (optional) ─────────────────────────────────────────────────
API_PORT=3000
WEB_PORT=80
SCRAPER_PORT=8001
