# VM deployment environment — written to /opt/soulstep/.env by GitHub Actions at every deploy.
# Copy this file to .env and fill in values for local VM testing.
# Never commit a filled-in .env file.

# ── VM / Deploy ────────────────────────────────────────────────────────────────
USE_SSL=false   # set to true once Let's Encrypt certs are issued

# ── PostgreSQL (runs inside Docker on the VM) ──────────────────────────────────
POSTGRES_USER=soulstep
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=soulstep
SCRAPER_POSTGRES_DB=soulstep_scraper

# ── Catalog API ────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
CATALOG_API_KEY=change-me-generate-with-openssl-rand-hex-32
GOOGLE_MAPS_API_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@soul-step.org
CORS_ORIGINS=https://soul-step.org https://www.soul-step.org https://admin.soul-step.org
FRONTEND_URL=https://soul-step.org
RESET_URL_BASE=https://soul-step.org
SENTRY_DSN=
ADS_ENABLED=false
ADSENSE_PUBLISHER_ID=

# ── GCS (shared by catalog + scraper) ─────────────────────────────────────────
GCS_BUCKET_NAME=soulstep-images
GOOGLE_CLOUD_PROJECT=project-fa2d7f52-2bc4-4a46-8ae

# ── Scraper API ────────────────────────────────────────────────────────────────
SCRAPER_GOOGLE_MAPS_API_KEY=
SCRAPER_GEMINI_API_KEY=
SCRAPER_FOURSQUARE_API_KEY=
SCRAPER_OUTSCRAPER_API_KEY=
SCRAPER_BESTTIME_API_KEY=
SCRAPER_ALLOWED_ORIGINS=https://admin.soul-step.org
SCRAPER_TIMEZONE=Asia/Dubai
# Scraper Cloud Run Job dispatch (production — do not change unless adding/removing regions)
CLOUD_RUN_JOB_NAME=soulstep-scraper-api-job
CLOUD_RUN_REGION=europe-west1
CLOUD_RUN_REGIONS=europe-west1:3,europe-west4:5
# VM internal GCP IP — used by the Cloud Run Job to reach postgres via Serverless VPC connector.
# Do not use the docker-internal hostname "postgres" here; Cloud Run cannot resolve it.
SCRAPER_CLOUD_RUN_DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@10.132.0.2:5432/${SCRAPER_POSTGRES_DB}
# Public URL of the catalog API, forwarded to Cloud Run scraper jobs.
# Cloud Run jobs cannot resolve the Docker-internal "catalog-api" hostname used by MAIN_SERVER_URL.
# Set to http://<VM_EXTERNAL_IP>:3000 (the VM's static external IP).
CLOUD_RUN_CATALOG_URL=http://<VM_EXTERNAL_IP>:3000
# GCP service account key — needed locally for GCS access; not used on the VM (uses ADC)
GOOGLE_APPLICATION_CREDENTIALS=

# ── Misc ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Backup ────────────────────────────────────────────────────────────────────
BACKUP_GCS_BUCKET=soulstep-db-backups
