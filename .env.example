# Root .env — shared / top-level environment variables
# Copy to .env and fill in values. Do not commit .env.
#
# For service-specific env vars, see the .env.example in each service directory:
#   soulstep-catalog-api/.env.example
#   soulstep-scraper-api/.env.example
#   apps/soulstep-customer-web/.env.example
#   apps/soulstep-customer-mobile/.env.example
#   apps/soulstep-admin-web/.env.example
#
# In production (GCP), sensitive values go into Secret Manager — see PRODUCTION.md.

# ── Backend (soulstep-catalog-api) ───────────────────────────────────────────

# Required in production. Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-long-random-secret

# Optional. Access token lifetime (default: 30m). Supports '30m', '1h', '7d', or integer minutes.
# JWT_EXPIRE=30m

# Optional. Refresh token lifetime (default: 30d).
# REFRESH_EXPIRE=30d

# Required in production. PostgreSQL connection string. Dev uses SQLite by default.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Required in production. Space-separated list of allowed CORS origins.
CORS_ORIGINS=http://localhost:5173 http://127.0.0.1:5173

# Optional. Public URL of the web frontend — used in sitemap, share pages, JSON-LD, email links.
# FRONTEND_URL=https://soul-step.org

# Optional. Public URL of this API — used in RSS/Atom feed self links and robots.txt.
# API_BASE_URL=https://api.soul-step.org

# Optional. Transactional email (Resend.com) — required for password-reset emails in production.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# RESEND_FROM_EMAIL=noreply@soul-step.org
# RESET_URL_BASE=https://soul-step.org

# Optional. Google Places API key — required for place search autocomplete.
# GOOGLE_MAPS_API_KEY=AIza...

# Optional. GCP project ID — required for GCS image storage and Cloud Translation.
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Optional. Image storage backend (default: blob — stored in DB).
# IMAGE_STORAGE=gcs
# GCS_BUCKET_NAME=soulstep-images

# Optional. Ads integration.
# ADS_ENABLED=true
# ADSENSE_PUBLISHER_ID=ca-pub-xxxxxxxxxxxxxxxx
# ADMOB_APP_ID_IOS=ca-app-pub-xxxxxxxxxxxxxxxx~yyyyyyyyyy
# ADMOB_APP_ID_ANDROID=ca-app-pub-xxxxxxxxxxxxxxxx~yyyyyyyyyy

# Optional. Mobile app version enforcement.
# MIN_APP_VERSION_SOFT=1.0.0
# MIN_APP_VERSION_HARD=1.0.0
# LATEST_APP_VERSION=1.0.0
# APP_STORE_URL_IOS=https://apps.apple.com/app/idXXXXXXXXX
# APP_STORE_URL_ANDROID=https://play.google.com/store/apps/details?id=com.soulstep

# ── Web frontend (apps/soulstep-customer-web) ────────────────────────────────
# Baked into the build at CI time. Set to your production API URL.
# VITE_API_URL=https://api.soul-step.org

# ── Scraper (soulstep-scraper-api) ────────────────────────────────────────────
# See soulstep-scraper-api/.env.example for the full list.
# GOOGLE_MAPS_API_KEY=AIza...   # shared with catalog if using same key
# SCRAPER_TIMEZONE=Asia/Dubai
