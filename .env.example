# VM deployment environment — written to /opt/soulstep/.env by GitHub Actions at every deploy.
# Copy this file to .env and fill in values for local VM testing.
# Never commit a filled-in .env file.

# ── VM / Deploy ────────────────────────────────────────────────────────────────
USE_SSL=false   # set to true once Let's Encrypt certs are issued

# ── PostgreSQL (runs inside Docker on the VM) ──────────────────────────────────
POSTGRES_USER=soulstep
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=soulstep

# ── Catalog API ────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
CATALOG_API_KEY=change-me-generate-with-openssl-rand-hex-32
GOOGLE_MAPS_API_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@soul-step.org
CORS_ORIGINS=https://soul-step.org https://www.soul-step.org https://admin.soul-step.org
FRONTEND_URL=https://soul-step.org
RESET_URL_BASE=https://soul-step.org
GLITCHTIP_DSN=
ADS_ENABLED=false
ADSENSE_PUBLISHER_ID=

# ── GCS (shared by catalog + scraper) ─────────────────────────────────────────
GCS_BUCKET_NAME=soulstep-images
GOOGLE_CLOUD_PROJECT=project-fa2d7f52-2bc4-4a46-8ae

# ── Scraper API ────────────────────────────────────────────────────────────────
SCRAPER_GOOGLE_MAPS_API_KEY=
SCRAPER_GEMINI_API_KEY=
SCRAPER_FOURSQUARE_API_KEY=
SCRAPER_ALLOWED_ORIGINS=https://admin.soul-step.org
SCRAPER_TIMEZONE=Asia/Dubai
CLOUD_RUN_REGIONS=europe-west1:3,europe-west4:5

# ── Misc ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Backup ────────────────────────────────────────────────────────────────────
BACKUP_GCS_BUCKET=soulstep-db-backups
