# SoulStep – Catalog API  (soulstep-catalog-api)
# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env before running locally.  Do not commit .env.
# In production (Cloud Run / GCP), inject these as Secret Manager secrets or
# Cloud Run environment variables — see PRODUCTION.md.
#
# Legend:
#   [required]    — must be set in production; a safe local-dev default exists
#   [optional]    — has a sensible built-in default; set only to override
#   [conditional] — required only when a related feature is enabled


# ── Internal Service Auth ─────────────────────────────────────────────────────

# [required] Shared secret for internal service-to-service calls (scraper → catalog API).
# Sent as the X-API-Key header by the scraper.  Must match CATALOG_API_KEY on the scraper.
# Generate: openssl rand -hex 32
# WARNING: required in production; any placeholder (e.g. "dev-key") works locally.
CATALOG_API_KEY=dev-key


# ── Auth / JWT ────────────────────────────────────────────────────────────────

# [required] HMAC-HS256 signing secret for access and refresh tokens.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# WARNING: the default below works for local dev but MUST be replaced in production.
JWT_SECRET=dev-secret-change-in-production

# [optional] Access-token lifetime.  Accepts '30m', '2h', '7d', or an integer
# number of minutes.  Default: 30m.
# JWT_EXPIRE=30m

# [optional] Refresh-token lifetime.  Same format as JWT_EXPIRE.  Default: 30d.
# REFRESH_EXPIRE=30d


# ── Database ──────────────────────────────────────────────────────────────────

# [optional] PostgreSQL connection string.  When unset the server falls back to
# SQLite (soulstep.db in the working directory) — fine for local development.
# DATABASE_URL=postgresql://user:password@host:5432/soulstep

# Cloud SQL (Cloud Run, Unix-socket):
# DATABASE_URL=postgresql+psycopg2://user:password@/soulstep?host=/cloudsql/PROJECT:REGION:INSTANCE

# [conditional] PostgreSQL connection string for the scraper's database.
# Required only when running the sync-places Cloud Run Job locally or in production.
# SCRAPER_DATABASE_URL=postgresql://user:password@host:5432/soulstep_scraper


# ── CORS ──────────────────────────────────────────────────────────────────────

# [required in production] Space-separated list of browser origins allowed to
# call this API.  When unset, defaults to localhost:5173 and localhost:3000
# (local dev only — do NOT leave unset in production).
# CORS_ORIGINS=https://soul-step.org https://www.soul-step.org


# ── Public URLs ───────────────────────────────────────────────────────────────

# [optional] Public URL of the customer-facing web app.
# Used in: OG share redirects, sitemap.xml, JSON-LD structured data, email links.
# Default: http://localhost:5173
# FRONTEND_URL=https://soul-step.org

# [optional] Public URL of this API.
# Used in: RSS/Atom feed self-links, robots.txt sitemap entry, llms.txt.
# Default: http://localhost:3000
# API_BASE_URL=https://api.soul-step.org


# ── Email — Resend.com ────────────────────────────────────────────────────────

# [optional] API key for transactional email (password-reset flows).
# When unset, the reset link is printed to the console instead (dev fallback).
# Get a free key at https://resend.com.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [optional] "From" address for outgoing emails.
# Must be a verified sender domain in your Resend account.
# Default: noreply@soul-step.org
# RESEND_FROM_EMAIL=noreply@soul-step.org

# [optional] Base URL prepended to the reset token when building reset-link emails.
# Default: http://localhost:5173
# RESET_URL_BASE=https://soul-step.org


# ── Logging ───────────────────────────────────────────────────────────────────

# [optional] Log verbosity.  Values: DEBUG | INFO | WARNING | ERROR
# Default: INFO
# LOG_LEVEL=INFO

# [optional] Log format.
#   json  (default) — structured JSON, suitable for Cloud Logging / Cloud Run
#   text            — human-readable, easier to read during local development
# LOG_FORMAT=text


# ── Google APIs ───────────────────────────────────────────────────────────────

# [optional] Google Places API key — required for place-search autocomplete.
# Enable "Places API (New)" on the key at console.cloud.google.com.
# Without this key all search-autocomplete requests return empty results.
# GOOGLE_MAPS_API_KEY=AIzaSy...

# [optional] GCP project ID.
# Required when using GCS image storage or Cloud Translation outside GCP.
# On Cloud Run, automatically inferred from the workload identity — safe to omit.
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# [optional] Path to a service-account JSON key file for GCP authentication.
# Only needed for local development when accessing GCS or Cloud Translation.
# On Cloud Run, workload identity (ADC) is used automatically — do NOT set this in production.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json


# ── Image Storage ─────────────────────────────────────────────────────────────

# [optional] Backend used to store place images.
#   blob  (default) — base64-encoded directly in the database; fine for SQLite
#                     and small deployments, but inflates DB size with many photos
#   gcs             — Google Cloud Storage; recommended for production
# IMAGE_STORAGE=blob

# [conditional] GCS bucket name.  Required when IMAGE_STORAGE=gcs.
# Must match the value of GCS_BUCKET_NAME in soulstep-scraper-api so both
# services share a single bucket.
# GCS_BUCKET_NAME=soulstep-images


# ── Scraper Service ───────────────────────────────────────────────────────────

# [optional] URL of the soulstep-scraper-api instance.
# Used by the admin scraper-proxy endpoints (/api/v1/admin/scraper/*).
# Default: http://localhost:8001
# DATA_SCRAPER_URL=http://127.0.0.1:8001


# ── Browser Translation ───────────────────────────────────────────────────────
# These settings control the Playwright-based translation Cloud Run Job
# (the `translate_content` management command).  They have no effect on normal
# API operation.

# [optional] Number of concurrent browser contexts.  Default: 20.
# BROWSER_POOL_SIZE=20

# [optional] Translations to process per context before recycling it to prevent
# memory bloat.  Default: 50.
# BROWSER_MAX_TRANSLATIONS=50

# [optional] Run the browser in headless mode.  Default: true.
# Set to false for local visual debugging.
# BROWSER_HEADLESS=true


# ── Ads Integration ───────────────────────────────────────────────────────────

# [optional] Master switch for the ads subsystem.
# When false (default), the ads-config endpoint returns empty values for all clients.
# ADS_ENABLED=false

# [conditional] Google AdSense publisher ID — required when ADS_ENABLED=true (web).
# Find it in AdSense console: Ads → Overview → Publisher ID.
# ADSENSE_PUBLISHER_ID=ca-pub-xxxxxxxxxxxxxxxxxxxxxxxx

# [conditional] Google AdMob App IDs — required when ADS_ENABLED=true (mobile).
# Get from AdMob console: Apps → App settings → App ID.
# ADMOB_APP_ID_IOS=ca-app-pub-xxxxxxxxxxxxxxxx~xxxxxxxxxx
# ADMOB_APP_ID_ANDROID=ca-app-pub-xxxxxxxxxxxxxxxx~xxxxxxxxxx


# ── Mobile App-Version Enforcement ───────────────────────────────────────────
# Leave all four variables unset (or empty) to disable version enforcement entirely.

# [optional] Soft update gate: clients below this semver see a non-blocking
# update banner but can still use the app.
# MIN_APP_VERSION_SOFT=1.0.0

# [optional] Hard update gate: clients below this semver receive HTTP 426 and
# are prevented from making API calls until they update.
# MIN_APP_VERSION_HARD=1.0.0

# [optional] Current latest release version — returned by GET /api/v1/app-version.
# LATEST_APP_VERSION=1.0.0

# [optional] App-store deep-link URLs shown inside update prompts.
# APP_STORE_URL_IOS=https://apps.apple.com/app/idXXXXXXXXX
# APP_STORE_URL_ANDROID=https://play.google.com/store/apps/details?id=com.soulstep


# ── Error Tracking — GlitchTip ────────────────────────────────────────────────

# [optional] Sentry-compatible DSN for server-side error and exception tracking.
# Get your DSN from your GlitchTip project settings at https://glitchtip.com.
# When unset, error tracking is disabled.
# GLITCHTIP_DSN=https://<key>@app.glitchtip.com/<project-id>
