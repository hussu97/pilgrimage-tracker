# SoulStep – Backend API (soulstep-catalog-api)
# Copy to .env and set values. Do not commit .env.

# ── JWT / Auth ────────────────────────────────────────────────────────────────
# Required in production. Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=dev-secret-change-in-production

# Optional. Access token lifetime (default: 30m). Supports '30m', '1h', '7d', or integer minutes.
JWT_EXPIRE=30m

# Optional. Refresh token lifetime (default: 30d).
REFRESH_EXPIRE=30d

# ── Server ────────────────────────────────────────────────────────────────────
# Optional. Port the server listens on (default: 3000).
PORT=3000

# ── Logging ───────────────────────────────────────────────────────────────────
# Optional. Log level: DEBUG | INFO | WARNING | ERROR (default: INFO)
# LOG_LEVEL=INFO
# Optional. Log format: json (default, for production) | text (human-readable, for local dev)
# LOG_FORMAT=text

# ── Database ──────────────────────────────────────────────────────────────────
# Optional. PostgreSQL connection string. When unset, SQLite (soulstep.db) is used for dev.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── CORS ──────────────────────────────────────────────────────────────────────
# Optional. Space-separated list of allowed origins (not comma-separated).
# When unset, defaults to localhost dev origins (5173 and 3000).
# CORS_ORIGINS=http://127.0.0.1:5173 https://soul-step.org

# ── URLs ──────────────────────────────────────────────────────────────────────
# Optional. Public URL of the web frontend — used in sitemap, share pages, JSON-LD, email links.
# FRONTEND_URL=https://soul-step.org

# Optional. Public URL of this API — used in RSS/Atom feed self links and robots.txt sitemap.
# API_BASE_URL=https://soulstep-api-834941457147.europe-west1.run.app

# ── Email (Resend.com) ────────────────────────────────────────────────────────
# Optional. Required for production password-reset emails. Get a key at resend.com.
# Without this, reset links are printed to the console (dev-only fallback).
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Optional. "From" address for outgoing emails. Must be a verified sender on Resend.
# RESEND_FROM_EMAIL=noreply@soul-step.org

# Optional. Base URL of the frontend — used to build the password-reset link in emails.
# RESET_URL_BASE=https://soul-step.org

# ── Google Cloud APIs ─────────────────────────────────────────────────────────
# Optional. Required for place search autocomplete. Get a key at console.cloud.google.com.
# Enable "Places API (New)" on the key. Without this, all searches return empty results.
# GOOGLE_MAPS_API_KEY=AIza...

# Optional. Required for the translation backfill script (backfill_translations.py).
# Enable "Cloud Translation API" at console.cloud.google.com.
# GOOGLE_TRANSLATE_API_KEY=AIza...
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# ── Translation Backend ───────────────────────────────────────────────────────
# Optional. Which translation engine to use: api (default) | browser
# TRANSLATION_BACKEND=api

# Optional. Fall back to API when browser backend returns None: true | false (default false)
# TRANSLATION_FALLBACK=false

# Optional. Number of concurrent browser contexts (default 10). Only used when TRANSLATION_BACKEND=browser.
# BROWSER_POOL_SIZE=10

# Optional. Translations per browser context before recycling (default 50). Only used when TRANSLATION_BACKEND=browser.
# BROWSER_MAX_TRANSLATIONS=50

# Optional. Run browser in headless mode (default true). Set false for local debugging.
# BROWSER_HEADLESS=true

# ── Image Storage ─────────────────────────────────────────────────────────────
# Optional. Storage backend: blob (default, stored in DB) | gcs (Google Cloud Storage)
# IMAGE_STORAGE=gcs
# GCS_BUCKET_NAME=soulstep-images
# Optional. Only needed when running outside GCP (local dev with GCS). On Cloud Run,
# workload identity (ADC) is used automatically — do not set this in production.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── Ads Integration ───────────────────────────────────────────────────────────
# Optional. Master switch for ads. When false, ad config endpoints return empty.
# ADS_ENABLED=true

# Optional. Web AdSense publisher ID.
# ADSENSE_PUBLISHER_ID=ca-pub-7902951158656200

# Optional. Mobile AdMob App IDs (from AdMob console).
# ADMOB_APP_ID_IOS=ca-app-pub-xxxxxxxxxxxxxxxx~yyyyyyyyyy
# ADMOB_APP_ID_ANDROID=ca-app-pub-xxxxxxxxxxxxxxxx~yyyyyyyyyy

# ── Mobile App Version Enforcement ───────────────────────────────────────────
# Optional. Soft update: mobile clients below this version see a banner. Empty = disabled.
# MIN_APP_VERSION_SOFT=1.0.0

# Optional. Hard update: mobile clients below this version get HTTP 426 (blocked). Empty = disabled.
# MIN_APP_VERSION_HARD=1.0.0

# Optional. Current latest release — returned by GET /api/v1/app-version.
# LATEST_APP_VERSION=1.0.0

# Optional. App store URLs shown in update prompts.
# APP_STORE_URL_IOS=https://apps.apple.com/app/idXXXXXXXXX
# APP_STORE_URL_ANDROID=https://play.google.com/store/apps/details?id=com.soulstep

# ── Scraper Service ───────────────────────────────────────────────────────────
# Optional. URL of soulstep-scraper-api — used by admin scraper proxy endpoints.
# DATA_SCRAPER_URL=http://127.0.0.1:8001

# Optional. PostgreSQL connection string for the scraper database — used by the
# sync-places Cloud Run Job to read scraped places from the scraper DB.
# Only needed when running the sync-places job locally or in production.
# SCRAPER_DATABASE_URL=postgresql://soulstep-scraper:password@/soulstep-scraper?host=/cloudsql/PROJECT_ID:REGION:soulstep-db

# ── GlitchTip / Error Tracking ───────────────────────────────────────────────
# Optional. Sentry-compatible DSN for server-side error tracking. Get from GlitchTip project.
# GLITCHTIP_DSN=https://<key>@app.glitchtip.com/<project>
