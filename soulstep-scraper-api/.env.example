# SoulStep – Scraper API (soulstep-scraper-api)
# Copy to .env and set values. Do not commit .env.

# ── Core ──────────────────────────────────────────────────────────────────────
# Required. Google Maps API key — used by the GMaps collector for place data and geocoding.
# Enable "Places API (New)" and "Geocoding API" at console.cloud.google.com.
GOOGLE_MAPS_API_KEY=your_api_key_here

# Required. URL of the catalog API — scraped places are synced here.
MAIN_SERVER_URL=http://localhost:3000

# Optional. Comma-separated list of allowed CORS origins for the scraper API (admin web).
# Default: http://localhost:5174,http://127.0.0.1:5174
# SCRAPER_ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174

# ── Database ──────────────────────────────────────────────────────────────────
# Optional. PostgreSQL connection string. When set, takes priority over SCRAPER_DB_PATH (SQLite).
# Use this in production (e.g. Cloud Run + Cloud SQL) or when sharing a database across instances.
# DATABASE_URL=postgresql://user:password@host:5432/scraper_db

# Optional. Path to SQLite database file (default: scraper.db in the working directory).
# Ignored when DATABASE_URL is set. On Cloud Run Jobs, use /tmp/scraper.db (ephemeral filesystem).
# SCRAPER_DB_PATH=scraper.db

# ── Logging ───────────────────────────────────────────────────────────────────
# Optional. Log level: DEBUG | INFO | WARNING | ERROR (default: INFO)
LOG_LEVEL=DEBUG
# Optional. Log format: text (default, human-readable) | json (for production)
# LOG_FORMAT=text

# ── Timezone ──────────────────────────────────────────────────────────────────
# Optional. Fallback timezone for places where Google Maps doesn't return a UTC offset.
# Uses IANA timezone names. Default: UTC.
SCRAPER_TIMEZONE=Asia/Dubai

# ── Optional Collectors ───────────────────────────────────────────────────────
# Each collector is skipped gracefully when its key is absent.

# Optional. BestTime.app API key — enriches places with busyness/crowd data.
# Get a key at besttime.app.
# BESTTIME_API_KEY=

# Optional. Foursquare API key — enriches places with categories and popularity.
# Get a key at location.foursquare.com.
# FOURSQUARE_API_KEY=

# Optional. Outscraper API key — provides extended reviews and ratings.
# Get a key at outscraper.com.
# OUTSCRAPER_API_KEY=

# ── LLM Description Quality ───────────────────────────────────────────────────
# Optional. Google AI Studio API key — used for LLM-based description quality assessment.
# When unset, heuristic-only quality scoring is used instead.
# Get a free key at https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=AIza...

# ── GCP (Cloud Run) ───────────────────────────────────────────────────────────
# Optional. GCP project ID — used for Cloud Run Jobs and Cloud SQL connections.
# Only needed when running on GCP; inferred from the environment on Cloud Run.
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# ── Wikipedia Relevance ───────────────────────────────────────────────────────
# Optional. Maximum distance (km) between a place and a Wikipedia article's
# coordinates before the article is rejected as irrelevant. Default: 100.
# WIKIPEDIA_MAX_DISTANCE_KM=100

# ── Concurrency Tuning ────────────────────────────────────────────────────────
# Optional. Max concurrent requests per scraping phase. Tune these to stay within
# Google Maps API rate limits or target system capacity.
# SCRAPER_DISCOVERY_CONCURRENCY=10
# SCRAPER_DETAIL_CONCURRENCY=20
# SCRAPER_ENRICHMENT_CONCURRENCY=10

# ── Quality Gate Thresholds ───────────────────────────────────────────────────
# Optional. Quality gate thresholds (default 0.75 — lower to pass more places, raise to be stricter)
# SCRAPER_GATE_IMAGE_DOWNLOAD=0.75
# SCRAPER_GATE_ENRICHMENT=0.75
# SCRAPER_GATE_SYNC=0.75

# ── Post-Sync Automation ──────────────────────────────────────────────────────
# Optional. Auto-SEO generation after sync.
# Set SCRAPER_TRIGGER_SEO_AFTER_SYNC=true to auto-trigger SEO generation after sync.
# SCRAPER_TRIGGER_SEO_AFTER_SYNC=false
# SCRAPER_CATALOG_ADMIN_TOKEN=  # JWT from POST /api/v1/auth/login (admin user)
