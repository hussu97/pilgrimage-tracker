# SoulStep – Scraper API (soulstep-scraper-api)
# Copy to .env and set values. Do not commit .env.

# ── Core ──────────────────────────────────────────────────────────────────────
# Required. Google Maps API key — used by the GMaps collector for place data and geocoding.
# Enable "Places API (New)" and "Geocoding API" at console.cloud.google.com.
GOOGLE_MAPS_API_KEY=your_api_key_here

# Required. URL of the catalog API — scraped places are synced here.
MAIN_SERVER_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
# Optional. Path to SQLite database file (default: scraper.db in the working directory).
# On Cloud Run Jobs, use /tmp/scraper.db (filesystem is ephemeral per job execution).
# SCRAPER_DB_PATH=scraper.db

# ── Logging ───────────────────────────────────────────────────────────────────
# Optional. Log level: DEBUG | INFO | WARNING | ERROR (default: INFO)
# LOG_LEVEL=INFO
# Optional. Log format: text (default, human-readable) | json (for production)
# LOG_FORMAT=text

# ── Timezone ──────────────────────────────────────────────────────────────────
# Optional. Fallback timezone for places where Google Maps doesn't return a UTC offset.
# Uses IANA timezone names. Default: UTC.
SCRAPER_TIMEZONE=Asia/Dubai

# ── Optional Collectors ───────────────────────────────────────────────────────
# Each collector is skipped gracefully when its key is absent.

# Optional. BestTime.app API key — enriches places with busyness/crowd data.
# Get a key at besttime.app.
# BESTTIME_API_KEY=

# Optional. Foursquare API key — enriches places with categories and popularity.
# Get a key at location.foursquare.com.
# FOURSQUARE_API_KEY=

# Optional. Outscraper API key — provides extended reviews and ratings.
# Get a key at outscraper.com.
# OUTSCRAPER_API_KEY=

# ── LLM Description Quality ───────────────────────────────────────────────────
# Optional. Anthropic API key — used for LLM-based description quality assessment.
# When unset, heuristic-only quality scoring is used instead.
# ANTHROPIC_API_KEY=sk-ant-...
