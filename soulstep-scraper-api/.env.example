# SoulStep – Scraper API (soulstep-scraper-api)
# Copy to .env and set values. Do not commit .env.

# ── Core ──────────────────────────────────────────────────────────────────────
# Required. Google Maps API key — used by the GMaps collector.
# Enable "Places API (New)" at console.cloud.google.com.
# Not required when SCRAPER_BACKEND=browser.
GOOGLE_MAPS_API_KEY=your_api_key_here

# Required. URL of the catalog API — scraped places are synced here.
MAIN_SERVER_URL=http://127.0.0.1:3000

# Optional. CORS origins for the scraper API (admin web).
# Default: http://localhost:5174,http://127.0.0.1:5174
# SCRAPER_ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174

# ── Server ────────────────────────────────────────────────────────────────────
# Optional. Port the scraper API listens on (default: 8001).
# PORT=8001

# ── Scraper Backend ───────────────────────────────────────────────────────────
# Optional. Discovery and detail-fetch backend:
#   api (default) — Google Places API HTTP calls; requires GOOGLE_MAPS_API_KEY
#   browser       — Playwright/Chromium, no API calls, no cost, ~24–48h per 10K places
# SCRAPER_BACKEND=api

# ── Job Dispatcher ────────────────────────────────────────────────────────────
# Optional. How scrape runs are executed after POST /runs:
#   local (default) — runs in-process via FastAPI BackgroundTasks; no GCP needed
#   cloud_run       — dispatches a Cloud Run Job via GCP Jobs API; API service stays lightweight
# SCRAPER_DISPATCH=local

# Cloud Run Job settings (only used when SCRAPER_DISPATCH=cloud_run)
# CLOUD_RUN_JOB_NAME=soulstep-scraper-job
# CLOUD_RUN_REGION=us-central1

# ── Browser Mode ──────────────────────────────────────────────────────────────
# Only used when SCRAPER_BACKEND=browser. Requires: pip install -r requirements-job.txt
# and: playwright install chromium
#
# MAPS_BROWSER_POOL_SIZE=2       # concurrent Chromium contexts (default: 2)
# MAPS_BROWSER_MAX_PAGES=30      # navigations per session before recycling (default: 30)
# MAPS_BROWSER_HEADLESS=true     # set false for local visual debugging

# ── Database ──────────────────────────────────────────────────────────────────
# Optional. PostgreSQL connection string. When set, takes priority over SCRAPER_DB_PATH.
# Use in production (Cloud Run + Cloud SQL) or when sharing data across instances.
# DATABASE_URL=postgresql://user:password@host:5432/scraper_db

# Optional. Path to SQLite database file (default: scraper.db in working directory).
# On Cloud Run Jobs, use /tmp/scraper.db (ephemeral filesystem).
# SCRAPER_DB_PATH=scraper.db

# Optional. PostgreSQL connection pool size (only used when DATABASE_URL is set).
# Pool budget: SCRAPER_POOL_SIZE + SCRAPER_MAX_OVERFLOW = max concurrent connections.
# Increase if you see "QueuePool limit of size N overflow N reached" errors during large runs.
# SCRAPER_POOL_SIZE=10
# SCRAPER_MAX_OVERFLOW=10
# SCRAPER_POOL_TIMEOUT=30

# ── Logging ───────────────────────────────────────────────────────────────────
# Optional. Log level: DEBUG | INFO | WARNING | ERROR (default: INFO)
LOG_LEVEL=DEBUG
# Optional. Log format: text (default, human-readable) | json (for Cloud Run)
# LOG_FORMAT=text

# ── Timezone ──────────────────────────────────────────────────────────────────
# Optional. Fallback timezone for places where Google Maps doesn't return a UTC offset.
# IANA timezone names. Default: UTC.
SCRAPER_TIMEZONE=Asia/Dubai

# ── GCP ───────────────────────────────────────────────────────────────────────
# Optional. GCP project ID — used for Cloud Run Jobs and Cloud SQL connections.
# Inferred automatically when running on Cloud Run.
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Required. GCS bucket for image storage — use the SAME bucket as the catalog API
# (i.e. the value of GCS_BUCKET_NAME in soulstep-catalog-api/.env).
# Scraped images are downloaded and uploaded to images/places/ in GCS before sync.
# Public HTTPS URLs are sent to the catalog in the sync payload.
GCS_BUCKET_NAME=soulstep-images

# ── Optional Collectors ───────────────────────────────────────────────────────
# Each collector is skipped gracefully when its key is absent.

# BestTime.app — busyness forecasts and peak hours
# BESTTIME_API_KEY=

# Foursquare — categories and popularity
# FOURSQUARE_API_KEY=

# Outscraper — extended reviews beyond Google's 5-review limit
# OUTSCRAPER_API_KEY=

# Google Knowledge Graph — entity descriptions (free, 100k/day; no key needed)
# KNOWLEDGE_GRAPH_API_KEY=

# ── LLM Description Quality ───────────────────────────────────────────────────
# Optional. Gemini API key — used for LLM tie-breaking when two descriptions score
# within 0.15 of each other (~10-20% of places). Free key at aistudio.google.com.
# When unset, heuristic-only quality scoring is used.
# GEMINI_API_KEY=AIza...

# ── Concurrency Tuning ────────────────────────────────────────────────────────
# Optional. Tune these to stay within API rate limits or system capacity.
# SCRAPER_DISCOVERY_CONCURRENCY=10   # max concurrent searchNearby calls
# SCRAPER_DETAIL_CONCURRENCY=20      # max concurrent getPlace calls
# SCRAPER_ENRICHMENT_CONCURRENCY=10  # max places enriched concurrently
# SCRAPER_MAX_PHOTOS=3               # photos per place (Photo Media: $0.007/1000)
# SCRAPER_IMAGE_CONCURRENCY=40       # max concurrent image downloads (CDN, no rate limit)
# SCRAPER_OVERPASS_CONCURRENCY=2     # max concurrent Overpass API requests
# SCRAPER_OVERPASS_JITTER_MAX=1.5    # random delay between Overpass requests (seconds)

# ── Wikipedia Relevance ───────────────────────────────────────────────────────
# Optional. Max distance (km) between a place and a Wikipedia article's coordinates
# before the article is rejected as irrelevant. Default: 100.
# WIKIPEDIA_MAX_DISTANCE_KM=100

# ── Quality Gate Thresholds ───────────────────────────────────────────────────
# Optional. Threshold 0.0–1.0: lower = more places pass, higher = stricter.
# SCRAPER_GATE_IMAGE_DOWNLOAD=0.75
# SCRAPER_GATE_ENRICHMENT=0.75
# SCRAPER_GATE_SYNC=0.75

# ── Post-Sync Automation ──────────────────────────────────────────────────────
# Optional. Auto-trigger SEO generation on the catalog API after sync completes.
# SCRAPER_TRIGGER_SEO_AFTER_SYNC=false
# SCRAPER_CATALOG_ADMIN_TOKEN=   # JWT from POST /api/v1/auth/login (admin user)
