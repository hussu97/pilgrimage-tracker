# SoulStep – Scraper API  (soulstep-scraper-api)
# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env before running locally.  Do not commit .env.
# In production (Cloud Run / GCP), inject these as Secret Manager secrets or
# Cloud Run environment variables — see PRODUCTION.md.
#
# Legend:
#   [required]    — must be set for the service to function
#   [optional]    — has a sensible built-in default; set only to override
#   [conditional] — required only when a related feature is enabled


# ── API Keys ──────────────────────────────────────────────────────────────────

# [required] Google Maps / Places API key — used by the GMaps collector for
# place discovery and detail fetching.
# Enable "Places API (New)" at console.cloud.google.com.
# Not required when SCRAPER_BACKEND=browser (browser mode makes no API calls).
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# [optional] Foursquare API key — enriches places with categories and popularity.
# Free tier available at https://foursquare.com/developer.
# When unset, the Foursquare collector is skipped gracefully.
# FOURSQUARE_API_KEY=fsq...

# [optional] Outscraper API key — retrieves extended Google reviews beyond the
# 5-review limit returned by the Places API.
# Sign up at https://outscraper.com.
# When unset, the Outscraper collector is skipped gracefully.
# OUTSCRAPER_API_KEY=...

# [optional] BestTime.app API key — adds busyness forecasts and peak-hours data.
# Sign up at https://besttime.app.
# When unset, the BestTime collector is skipped gracefully.
# BESTTIME_API_KEY=...

# [optional] Google Knowledge Graph API key — fetches entity descriptions for places.
# Free at 100k requests/day; get a key at console.cloud.google.com.
# When unset, the Knowledge Graph collector is skipped gracefully.
# KNOWLEDGE_GRAPH_API_KEY=AIzaSy...

# [optional] Google Gemini API key — used for LLM tie-breaking when two candidate
# descriptions score within 0.15 of each other (~10–20% of places).
# Free key at https://aistudio.google.com.
# When unset, heuristic-only quality scoring is used.
# GEMINI_API_KEY=AIzaSy...


# ── Runtime ───────────────────────────────────────────────────────────────────

# [required] URL of the soulstep-catalog-api — scraped places are synced here.
# Default: http://127.0.0.1:3000
MAIN_SERVER_URL=http://127.0.0.1:3000

# [optional] Comma-separated list of origins allowed to call this scraper API.
# Typically the admin web app running locally or in production.
# Default: http://localhost:5174,http://127.0.0.1:5174
# SCRAPER_ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174

# [optional] Fallback IANA timezone for places where Google Maps does not return
# a UTC offset (e.g. newly added or unmapped places).  Default: UTC.
# SCRAPER_TIMEZONE=Asia/Dubai


# ── Database ──────────────────────────────────────────────────────────────────

# [optional] PostgreSQL connection string.  When set, takes priority over
# SCRAPER_DB_PATH and is used for all DB operations.
# Use in production (Cloud Run + Cloud SQL) or when sharing data across instances.
# DATABASE_URL=postgresql://user:password@host:5432/soulstep_scraper

# Cloud SQL (Cloud Run, Unix-socket):
# DATABASE_URL=postgresql+psycopg2://user:password@/soulstep_scraper?host=/cloudsql/PROJECT:REGION:INSTANCE

# [optional] Path to the SQLite database file.  Only used when DATABASE_URL is unset.
# Default: scraper.db in the working directory.
# Local development only — do NOT use this in production.  Cloud Run containers have
# an ephemeral filesystem; all SQLite data is lost when the container exits.
# Set DATABASE_URL (PostgreSQL) for any persistent production deployment.
# SCRAPER_DB_PATH=scraper.db

# [optional] PostgreSQL connection-pool tuning.  Only applied when DATABASE_URL
# is set to a PostgreSQL URL.  Raise if you see "QueuePool limit … reached"
# errors during large concurrent runs.
# Budget: SCRAPER_POOL_SIZE + SCRAPER_MAX_OVERFLOW = max concurrent connections.
# SCRAPER_POOL_SIZE=10      # persistent connections kept open per process
# SCRAPER_MAX_OVERFLOW=10   # extra connections allowed during traffic bursts
# SCRAPER_POOL_TIMEOUT=30   # seconds to wait for a free connection before error


# ── Logging ───────────────────────────────────────────────────────────────────

# [optional] Log verbosity.  Values: DEBUG | INFO | WARNING | ERROR
# Default: INFO
LOG_LEVEL=DEBUG

# [optional] Log format.
#   text  (default) — human-readable, easier to read during local development
#   json            — structured JSON, suitable for Cloud Logging / Cloud Run
# LOG_FORMAT=text


# ── Scraper Backend ───────────────────────────────────────────────────────────

# [optional] Discovery and detail-fetch backend:
#   api      (default) — Google Places API HTTP calls; fast and reliable;
#                        requires GOOGLE_MAPS_API_KEY; costs ~$8 per 10K places
#   browser            — Playwright/Chromium; no API calls, no cost, stealth-based;
#                        ~24–48 h per 10K places; requires `playwright install chromium`
# SCRAPER_BACKEND=api


# ── Job Dispatcher ────────────────────────────────────────────────────────────

# [optional] How scrape runs are executed after POST /runs:
#   local      (default) — runs in-process via FastAPI BackgroundTasks; no GCP needed
#   cloud_run            — dispatches a Cloud Run Job via the GCP Jobs API;
#                          keeps the API service lightweight for large runs
# SCRAPER_DISPATCH=local

# [conditional] Cloud Run Job name — required when SCRAPER_DISPATCH=cloud_run.
# Default: soulstep-scraper-job
# CLOUD_RUN_JOB_NAME=soulstep-scraper-job

# [conditional] GCP region for Cloud Run Job dispatch — required when SCRAPER_DISPATCH=cloud_run.
# Default: us-central1
# CLOUD_RUN_REGION=us-central1


# ── GCP ───────────────────────────────────────────────────────────────────────

# [optional] GCP project ID.
# Required for Cloud Run Job dispatch and Cloud SQL connections outside GCP.
# On Cloud Run, automatically inferred from the workload identity — safe to omit.
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# [conditional] GCS bucket for scraped image storage.
# Required when the catalog API is configured with IMAGE_STORAGE=gcs.
# Must match the value of GCS_BUCKET_NAME in soulstep-catalog-api so both
# services share a single bucket and place images share one folder (images/places/).
# GCS_BUCKET_NAME=soulstep-images


# ── Concurrency Tuning ────────────────────────────────────────────────────────
# All concurrency limits default to values that work well on a single Cloud Run
# instance.  Reduce them if you hit API rate limits; raise them (carefully) for
# faster runs on larger instances.

# [optional] Max concurrent Google Places searchNearby calls during discovery.
# Default: 10
# SCRAPER_DISCOVERY_CONCURRENCY=10

# [optional] Max concurrent Google Places getPlace detail calls.
# Default: 20
# SCRAPER_DETAIL_CONCURRENCY=20

# [optional] Max places enriched (all collectors) in parallel.
# Default: 10
# SCRAPER_ENRICHMENT_CONCURRENCY=10

# [optional] Max concurrent Overpass API requests across all enrichment workers.
# Keep low — Overpass is a public server with strict rate limits.
# Default: 2
# SCRAPER_OVERPASS_CONCURRENCY=2

# [optional] Max random jitter (seconds) injected before each Overpass request
# to spread burst load.  Default: 1.5
# SCRAPER_OVERPASS_JITTER_MAX=1.5

# [optional] Max photos stored per place.
# Google charges $0.007 per 1000 Photo Media requests — 3 covers list cards
# and the detail-page hero; raise to 5–10 only if you need a richer gallery.
# Default: 3
# SCRAPER_MAX_PHOTOS=3

# [optional] Max reviews scraped per place (Google Places API and browser extraction).
# Default: 5
# SCRAPER_MAX_REVIEWS=5

# [optional] Max concurrent image downloads (plain CDN, no API rate limit).
# Default: 40
# SCRAPER_IMAGE_CONCURRENCY=40


# ── Quality Gate Thresholds ───────────────────────────────────────────────────
# Each gate is a 0.0–1.0 quality score: places below the threshold are dropped
# before the next pipeline stage.  Lower = more permissive, higher = stricter.

# [optional] Minimum score to pass the image-download gate.  Default: 0.75
# SCRAPER_GATE_IMAGE_DOWNLOAD=0.75

# [optional] Minimum score to pass the enrichment gate.  Default: 0.75
# SCRAPER_GATE_ENRICHMENT=0.75

# [optional] Minimum score to pass the sync gate (written to catalog).  Default: 0.75
# SCRAPER_GATE_SYNC=0.75


# ── Wikipedia Relevance ───────────────────────────────────────────────────────

# [optional] Maximum distance in kilometres between a place's coordinates and a
# Wikipedia article's coordinates before the article is rejected as irrelevant.
# Default: 100
# WIKIPEDIA_MAX_DISTANCE_KM=100


# ── Browser Mode ──────────────────────────────────────────────────────────────
# These settings only apply when SCRAPER_BACKEND=browser.
# Prerequisites: pip install -r requirements-job.txt && playwright install chromium

# [optional] Side-length (km) of each fixed grid cell used to tile a search area
# during browser-based grid discovery.  Smaller = more overlap, more coverage.
# Default: 3.0
# BROWSER_GRID_CELL_SIZE_KM=3.0

# [optional] Number of concurrent Playwright browser contexts.
# Each context is an isolated browser session with its own cookies and fingerprint.
# Default: 3
# MAPS_BROWSER_POOL_SIZE=3

# [optional] Maximum page navigations per browser context before recycling it.
# Recycling prevents fingerprint buildup that can trigger bot detection.
# Default: 30
# MAPS_BROWSER_MAX_PAGES=30

# [optional] Run Chromium in headless mode.  Default: true.
# Set to false for local visual debugging (opens a visible browser window).
# MAPS_BROWSER_HEADLESS=true

# [optional] Max concurrent grid-cell navigations across all browser contexts.
# Keep at 1 (sequential) to avoid Google's concurrent-request bot detection.
# Raise to 2–3 only when using rotating proxies or multiple outbound IPs.
# Default: 3
# MAPS_BROWSER_CONCURRENCY=3

# [optional] Minimum random delay (seconds) between consecutive cell navigations.
# Mimics human think-time; helps avoid bot-detection on Maps.  Default: 5.0
# MAPS_BROWSER_CELL_DELAY_MIN=5.0

# [optional] Maximum random delay (seconds) between consecutive cell navigations.
# Delay is sampled uniformly from [CELL_DELAY_MIN, CELL_DELAY_MAX].  Default: 12.0
# MAPS_BROWSER_CELL_DELAY_MAX=12.0


# ── Post-Sync Automation ──────────────────────────────────────────────────────

# [optional] Automatically sync scraped places to the catalog API immediately
# after enrichment completes — no manual POST /runs/{code}/sync step needed.
# Requires MAIN_SERVER_URL and CATALOG_API_KEY.  Default: false.
# SCRAPER_AUTO_SYNC_AFTER_RUN=false

# [optional] Automatically call the catalog API's SEO-generation endpoint after
# each sync completes.  Requires CATALOG_API_KEY.  Default: false.
# SCRAPER_TRIGGER_SEO_AFTER_SYNC=false

# [required] Shared secret for catalog API internal endpoints (X-API-Key header).
# Must match CATALOG_API_KEY set on the catalog API service.
# Generate: openssl rand -hex 32
# CATALOG_API_KEY=
