# Required
GOOGLE_MAPS_API_KEY=your_api_key_here
MAIN_SERVER_URL=http://localhost:3000

# Fallback timezone for places where Google Maps doesn't return a UTC offset.
# Uses IANA timezone names (e.g. Asia/Dubai, America/New_York, Europe/London).
SCRAPER_TIMEZONE=Asia/Dubai

# Optional collectors (leave blank to disable)
BESTTIME_API_KEY=
FOURSQUARE_API_KEY=
OUTSCRAPER_API_KEY=

# LLM-based description assessment (leave blank to use heuristic-only)
ANTHROPIC_API_KEY=
