# Pilgrimage Tracker – Backend API
# Copy to .env and set values. Do not commit .env.

# ── JWT / Auth ──────────────────────────────────────────────────────────────
# Required in production; change from default before deploying.
JWT_SECRET=dev-secret-change-in-production

# Access token lifetime. Supports '30m', '1h', '7d', or integer minutes.
JWT_EXPIRE=30m

# Refresh token lifetime. Default: 30 days.
REFRESH_EXPIRE=30d

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000

# ── Database ────────────────────────────────────────────────────────────────
# Optional: PostgreSQL. When unset, SQLite (pilgrimage.db) is used for dev.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── CORS ────────────────────────────────────────────────────────────────────
# Space-separated list of allowed origins. When unset, defaults to localhost
# dev origins (5173 and 3000).
# CORS_ORIGINS=http://127.0.0.1:5173 https://app.example.com

# ── Email (Resend.com) ──────────────────────────────────────────────────────
# Required for production password-reset emails. Get a key at resend.com.
# Without this, reset links are printed to the console (dev-only fallback).
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# The "from" address used in outgoing emails. Must be a verified sender on Resend.
# RESEND_FROM_EMAIL=noreply@your-domain.com

# Base URL of the frontend. Used to build the password-reset link in emails.
# RESET_URL_BASE=https://app.example.com

# ── Google Places API ────────────────────────────────────────────────────────
# Required for place search autocomplete. Get a key at console.cloud.google.com.
# Enable "Places API (New)" on the key. Without this, all searches return empty.
# GOOGLE_MAPS_API_KEY=AIza...
