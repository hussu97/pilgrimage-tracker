# Pilgrimage Tracker – Backend API
# Copy to .env and set values. Do not commit .env.

# Required in production; optional in dev (defaults below)
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRE=7d

# Server
PORT=3000

# Optional: PostgreSQL. When unset, in-memory stores are used for dev.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional: space-separated list of CORS origins. When unset, defaults allow
# http://localhost:5173, http://127.0.0.1:5173, http://localhost:3000, http://127.0.0.1:3000
# CORS_ORIGINS=http://127.0.0.1:5173 https://app.example.com
